# N2L8Studio — Environment Variables
# Copy this to `.env` and fill in your values.
# On simply.com, set these in the hosting control panel instead.

# ── Database (MySQL) ──────────────────────────────────────────────────────────
DB_HOST=your-mysql-host.simply.com
DB_USER=your_db_username
DB_PASS=your_db_password
DB_NAME=n2l8studio
DB_PORT=3306

# ── Security ──────────────────────────────────────────────────────────────────
# Change this to a long random string in production!
SECRET_KEY=change-this-to-something-secret-and-random
