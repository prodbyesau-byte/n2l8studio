# ==============================================================================
# Flutter Git Ignore Rules
# ==============================================================================

# Custom sensitive configuration keys
.env

# Tooling and compiled outputs
.dart_tool/
.flutter-plugins
.flutter-plugins-dependencies
.packages
.pub-cache/
.pub/
/build/

# Android-specific ignores
/android/app/key.properties
**/*.keystore
**/*.jks
.gradle/
local.properties
/android/app/src/main/res/values/strings.xml

# iOS-specific ignores
.ios/
.bundle/
/ios/Flutter/.last_build_id
/ios/Flutter/Generated.xcconfig
/ios/Flutter/flutter_export_environment.sh
/ios/Runner/GeneratedPluginRegistrant.h
/ios/Runner/GeneratedPluginRegistrant.m
/ios/Runner/GeneratedPluginRegistrant.swift
/ios/Pods/
Podfile.lock

# Web and desktop directories
/web/
/windows/
/macos/
/linux/

# IDE configurations
.idea/
.vscode/
*.app_state
*.iml
